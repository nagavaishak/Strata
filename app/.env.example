# Public — safe to expose to the browser.
# The public endpoint is fine for local dev. Production uses a Helius devnet
# endpoint instead (set directly in Vercel, not committed here) -- the public
# node prunes transaction history within hours, which broke /verify's tx-hash
# display; see "Devnet RPC transaction-history retention" in DEVNET.md.
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com

# Server-only — never prefixed with NEXT_PUBLIC_, never sent to the client.
# The keypair used to authenticate with TxLINE's API (subscribe/guest-JWT/API-token
# flow) — same keypair scripts/*.ts use as ~/.config/solana/oracle-keypair.json.
# For local dev, leave ORACLE_KEYPAIR_JSON unset and it reads that file directly.
# For deployment (no local filesystem to read from), paste the keypair file's JSON
# array contents verbatim into ORACLE_KEYPAIR_JSON.
ORACLE_KEYPAIR_PATH=~/.config/solana/oracle-keypair.json
ORACLE_KEYPAIR_JSON=
TXLINE_API_BASE=https://txline-dev.txodds.com
