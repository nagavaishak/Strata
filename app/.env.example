# Public — safe to expose to the browser.
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com

# Server-only — never prefixed with NEXT_PUBLIC_, never sent to the client.
# Base58-encoded secret key bytes for the writer keypair used to authenticate with
# TxLINE's API (subscribe/guest-JWT/API-token flow). Same keypair used across
# scripts/*.ts as ~/.config/solana/oracle-keypair.json.
ORACLE_KEYPAIR_SECRET=
TXLINE_API_BASE=https://txline-dev.txodds.com
